{{> layout/header}}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card">
                <div class="card-header text-center">
                    <h3>회원가입 (Step 1)</h3>
                </div>
                <div class="card-body">
                    <form>
                        <div class="mb-3">
                            <label for="username" class="form-label">아이디</label>
                            <div class="input-group">
                                <input type="text" class="form-control" id="username" placeholder="아이디를 입력하세요">
                                <button type="button" class="btn btn-outline-primary" onclick="usernameCheck()">중복체크</button>
                            </div>
                            <div id="username-msg" class="form-text mt-2">아이디 중복 확인을 해주세요.</div>
                        </div>

                        <div class="mb-3">
                            <label for="password" class="form-label">비밀번호</label>
                            <input type="password" class="form-control" id="password" disabled>
                        </div>

                        <div class="mb-3">
                            <label for="email" class="form-label">이메일</label>
                            <input type="email" class="form-control" id="email" disabled>
                        </div>

                        <div class="d-grid gap-2">
                            <button id="btn-join" class="btn btn-primary" type="button" disabled>가입하기</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    // 아이디 중복 체크 여부 상태 관리
    let isUsernameChecked = false;

    /**
     * 아이디 중복 체크 (AJAX)
     */
    async function usernameCheck() {
        const username = document.querySelector("#username").value;
        const msgElement = document.querySelector("#username-msg");
        const btnJoin = document.querySelector("#btn-join");

        if (!username || username.trim() === "") {
            alert("아이디를 입력해주세요.");
            return;
        }

        try {
            // Fetch API를 활용한 비동기 통신
            const response = await fetch(`/api/username-check?username=${username}`);
            const result = await response.json(); // Resp<T> 구조로 수신

            // result.body: true(중복), false(사용 가능)
            if (result.body === true) {
                msgElement.innerHTML = "<span class='text-danger'>이미 존재하는 아이디입니다.</span>";
                isUsernameChecked = false;
                btnJoin.disabled = true;
            } else {
                msgElement.innerHTML = "<span class='text-success'>사용 가능한 아이디입니다.</span>";
                isUsernameChecked = true;
                
                // 가입 시나리오상 다음 단계 활성화 (현재는 Step 1이므로 버튼만 활성화)
                btnJoin.disabled = false;
                document.querySelector("#password").disabled = false;
                document.querySelector("#email").disabled = false;
            }
        } catch (error) {
            console.error("중복 체크 중 오류 발생:", error);
            alert("중복 체크 중 서버 오류가 발생했습니다.");
        }
    }

    // 아이디 입력란 변경 시 중복 체크 상태 초기화
    document.querySelector("#username").addEventListener("input", () => {
        isUsernameChecked = false;
        document.querySelector("#username-msg").innerText = "아이디 중복 확인을 해주세요.";
        document.querySelector("#btn-join").disabled = true;
    });
</script>

{{> layout/footer}}
