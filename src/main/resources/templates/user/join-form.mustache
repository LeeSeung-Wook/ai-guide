{{> layout/header}}

<div class="container my-5">
    <div class="row justify-content-center">
        <div class="col-lg-5 col-md-8">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-white py-3 border-0">
                    <h4 class="text-center mb-0 fw-bold">회원가입</h4>
                </div>
                <div class="card-body p-4">
                    <!-- 폼 전송 방식으로 변경 (x-www-form-urlencoded) -->
                    <form action="/join" method="post" id="join-form">
                        <!-- 아이디 입력 및 중복 체크 -->
                        <div class="mb-4">
                            <label for="username" class="form-label fw-semibold">아이디</label>
                            <div class="input-group">
                                <input type="text" 
                                       class="form-control" 
                                       id="username" 
                                       name="username" 
                                       placeholder="아이디를 입력하세요" 
                                       required>
                                <button type="button" 
                                        class="btn btn-outline-primary px-3" 
                                        id="btn-username-check" 
                                        onclick="usernameCheck()">중복체크</button>
                            </div>
                            <div id="username-msg" class="form-text mt-2 small">사용할 아이디의 중복 여부를 확인해주세요.</div>
                        </div>

                        <!-- 비밀번호 -->
                        <div class="mb-4">
                            <label for="password" class="form-label fw-semibold">비밀번호</label>
                            <input type="password" 
                                   class="form-control" 
                                   id="password" 
                                   name="password" 
                                   placeholder="비밀번호를 입력하세요" 
                                   disabled 
                                   required>
                            <div id="password-msg" class="form-text mt-1 small">영문, 숫자를 포함한 4~20자 이내</div>
                        </div>

                        <!-- 이메일 -->
                        <div class="mb-4">
                            <label for="email" class="form-label fw-semibold">이메일</label>
                            <input type="email" 
                                   class="form-control" 
                                   id="email" 
                                   name="email" 
                                   placeholder="example@email.com" 
                                   disabled 
                                   required>
                            <div id="email-msg" class="form-text mt-1 small">정확한 이메일 주소를 입력해주세요.</div>
                        </div>

                        <!-- 가입하기 버튼 -->
                        <div class="d-grid gap-2 mt-5">
                            <button id="btn-join" 
                                    class="btn btn-primary btn-lg fw-bold py-2" 
                                    type="submit" 
                                    disabled>가입하기</button>
                        </div>
                    </form>
                </div>
                <div class="card-footer bg-white py-3 border-0 text-center">
                    <span class="text-muted small">이미 계정이 있으신가요?</span>
                    <a href="/login-form" class="text-primary small text-decoration-none fw-semibold ms-1">로그인하기</a>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    /**
     * 아이디 중복 체크 (AJAX)
     */
    async function usernameCheck() {
        const usernameInput = document.querySelector("#username");
        const username = usernameInput.value.trim();
        const msgElement = document.querySelector("#username-msg");
        const btnJoin = document.querySelector("#btn-join");
        const passwordInput = document.querySelector("#password");
        const emailInput = document.querySelector("#email");

        if (!username) {
            alert("아이디를 입력해주세요.");
            return;
        }

        try {
            const response = await fetch(`/api/username-check?username=${username}`);
            const result = await response.json();

            if (result.body === true) {
                msgElement.innerHTML = "<span class='text-danger'>이미 존재하는 아이디입니다.</span>";
                btnJoin.disabled = true;
                passwordInput.disabled = true;
                emailInput.disabled = true;
            } else {
                msgElement.innerHTML = "<span class='text-success fw-semibold'>사용 가능한 아이디입니다.</span>";
                // 가입 시나리오상 중복 체크 통과 시 다음 필드 및 버튼 활성화
                btnJoin.disabled = false;
                passwordInput.disabled = false;
                emailInput.disabled = false;
                // 중복 체크 완료 후 아이디 수정 불가능하게 처리하거나, 수정 시 다시 체크하게 로직 구성
            }
        } catch (error) {
            console.error("중복 체크 오류:", error);
            alert("서버 오류가 발생했습니다.");
        }
    }

    /**
     * 아이디 입력 시 상태 초기화
     */
    document.querySelector("#username").addEventListener("input", () => {
        document.querySelector("#username-msg").innerHTML = "사용할 아이디의 중복 여부를 확인해주세요.";
        document.querySelector("#btn-join").disabled = true;
        document.querySelector("#password").disabled = true;
        document.querySelector("#email").disabled = true;
    });
</script>

{{> layout/footer}}
